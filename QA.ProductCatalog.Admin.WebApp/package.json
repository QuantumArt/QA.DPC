    "transform": {
      "^.+\\.(jsx?|tsx?)$": "ts-jest"
    },
    "testRegex": "(/__tests__/.+|.+\\.(test|spec))\\.(jsx?|tsx?)$",
    "moduleDirectories": [
      "node_modules",
      "ClientApp",
      "ClientApp/Packages"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "globals": {
      "ts-jest": {
        "skipBabel": true
      }
    }
  }
