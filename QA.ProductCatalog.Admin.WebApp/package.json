{
  "private": true,
  "name": "qa.productcatalog.admin.webapp",
  "version": "1.0.0",
  "description": "DPC Admin Web App",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "cd .. && husky QA.ProductCatalog.Admin.WebApp/.husky",
    "components:build-dev": "webpack --config webpack.dev.js && npm run bundles:build-dev",
    "components:build-prod": "webpack --config webpack.prod.js && npm run bundles:build-prod",
    "components:start": "npm run bundles:build-dev && webpack --config webpack.dev.js --watch",
    "test": "jest",
    "bundles:build-dev": "node build-bundles.js --dev",
    "bundles:build-prod": "node build-bundles.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,scss,css,md}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "ie 11",
    "not ie 10"
  ],
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "node-sass": "npm:sass@latest",
    "minimatch": "^9.0.0",
    "tar": "^7.5.10",
    "cacache": "^18.0.0",
    "gaze": "npm:chokidar@latest",
    "@tootallnate/once": "^3.0.1",
